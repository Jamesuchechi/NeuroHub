	"type": "module",
	"scripts": {
		"dev": "NODE_OPTIONS=--dns-result-order=ipv4first vite dev",
		"build": "NODE_OPTIONS=--dns-result-order=ipv4first vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
